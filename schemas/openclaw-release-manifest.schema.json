{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.heang.top/schemas/loom-release-manifest.schema.json",
  "title": "LOOM Release Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "product",
    "channel",
    "version",
    "publishedAt",
    "minLauncherVersion",
    "signature",
    "components"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "product": {
      "type": "string",
      "minLength": 1
    },
    "channel": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "publishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "minLauncherVersion": {
      "type": "string",
      "minLength": 1
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": {
          "const": "ed25519"
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/component"
      }
    },
    "distribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mirrors", "layers"],
      "properties": {
        "mirrors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "layers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/distributionLayer"
          }
        }
      }
    }
  },
  "$defs": {
    "distributionLayer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "file", "sha256", "installPath"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string"
        },
        "file": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "installPath": {
          "type": "string",
          "pattern": "^LOOMFiles[\\\\/].+"
        },
        "version": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "component": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "name",
        "version",
        "platform",
        "arch",
        "type",
        "size",
        "sha256",
        "urls",
        "installPath"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "platform": {
          "type": "string",
          "minLength": 1
        },
        "arch": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["zip", "tgz", "installer"]
        },
        "size": {
          "type": "integer",
          "minimum": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "urls": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "installPath": {
          "type": "string",
          "minLength": 1
        },
        "entry": {
          "type": "string"
        },
        "healthCheck": {
          "type": "object"
        },
        "rollback": {
          "type": "object"
        }
      }
    }
  }
}
