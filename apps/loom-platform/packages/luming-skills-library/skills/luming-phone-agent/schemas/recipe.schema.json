{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loom.local/schemas/phone-agent/recipe.schema.json",
  "title": "LOOM Phone Agent Recipe",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "recipeId",
    "name",
    "aliases",
    "status",
    "app",
    "goal",
    "mode",
    "prerequisites",
    "steps",
    "safety",
    "verification",
    "source"
  ],
  "properties": {
    "schema": {
      "const": "loom.phone-agent.recipe.v1"
    },
    "recipeId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "minLength": 1,
      "maxLength": 96
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "aliases": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "enum": ["draft", "verified", "stale", "blocked"]
    },
    "app": {
      "$ref": "#/$defs/app"
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": ["single", "matrix"]
    },
    "prerequisites": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/step"
      }
    },
    "safety": {
      "$ref": "#/$defs/safety"
    },
    "verification": {
      "$ref": "#/$defs/verification"
    },
    "source": {
      "$ref": "#/$defs/source"
    }
  },
  "$defs": {
    "app": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packageName", "versionRange", "entryPage"],
      "properties": {
        "packageName": {
          "type": "string",
          "minLength": 1
        },
        "versionRange": {
          "type": "string",
          "minLength": 1
        },
        "entryPage": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stepId",
        "action",
        "requiresConfirmation",
        "verification",
        "evidence"
      ],
      "properties": {
        "stepId": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "requiresConfirmation": {
          "type": "boolean"
        },
        "verification": {
          "enum": ["verified", "unknown"]
        },
        "evidence": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "pageFingerprint": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "reference", "assertion"],
      "properties": {
        "type": {
          "enum": ["screenshot", "page-fingerprint", "control-state", "visible-assertion"]
        },
        "reference": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#-]*$"
        },
        "assertion": {
          "$ref": "#/$defs/evidenceAssertion"
        }
      }
    },
    "evidenceAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["predicate", "subject", "expected"],
      "properties": {
        "predicate": {
          "enum": ["visible", "present", "selected", "enabled", "checked", "matches"]
        },
        "subject": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#-]*$"
        },
        "expected": {
          "type": "boolean"
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requiresHumanReview", "stopBefore"],
      "properties": {
        "requiresHumanReview": {
          "type": "boolean"
        },
        "stopBefore": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["successCount"],
      "properties": {
        "successCount": {
          "type": "integer",
          "minimum": 0
        },
        "lastSuccessfulRun": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "enum": ["builtin", "observed"]
        },
        "deviceId": {
          "type": "string",
          "minLength": 1
        },
        "pageFingerprint": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
