{
  "name": "loom-launcher",
  "version": "2.3.2",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:node-runtime": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-node-runtime.ps1",
    "build:python-runtime": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-python-runtime.ps1",
    "build:platform-tools": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-platform-tools.ps1",
    "build": "tsc && vite build",
    "test:platform-contracts": "tsc --noEmit && node --import tsx --test src/components/controlIntegrity.test.ts src/components/agent/agentFrontendIntegrity.test.ts src/components/agent/agentViewModel.test.ts src/components/matrix/matrixViewModel.test.ts src/components/phone/phoneConnectionState.test.ts src/components/update/UpdateCenter.test.ts src/services/api.test.ts src/services/platformContracts.test.ts src/services/realtimeStream.test.ts src/stores/agentStore.test.ts src/stores/appNavigation.test.ts",
    "test:node-contracts": "node --test scripts/openclaw-phone-agent-fast-path.test.mjs scripts/openclaw-phone-daemon.test.mjs scripts/openclaw-media-phone.test.mjs scripts/tests/openclaw-image-phone-contract.test.mjs scripts/tests/phone-frame-paths.test.mjs scripts/tests/publish-contract.test.mjs scripts/tests/vision-safety.test.mjs",
    "test:e2e": "tsc --noEmit -p tests/e2e/tsconfig.json && playwright test",
    "verify:phone": "powershell -ExecutionPolicy Bypass -File scripts/verify-phone-agent.ps1",
    "phone:image": "node scripts/openclaw-image-phone.mjs",
    "phone:image:edit": "node scripts/openclaw-image-phone.mjs --mode edit",
    "phone:agent": "node scripts/openclaw-phone-agent.mjs",
    "phone:fleet": "node scripts/openclaw-phone-fleet.mjs",
    "phone:video": "node scripts/openclaw-phone-video.mjs",
    "phone:vision": "node scripts/openclaw-phone-vision.mjs",
    "phone:game": "node scripts/openclaw-phone-game.mjs",
    "phone:publish": "node scripts/openclaw-publish-phone.mjs",
    "phone:relay": "node scripts/openclaw-publish-relay.mjs",
    "phone:relay:check": "node scripts/openclaw-publish-relay-check.mjs",
    "phone:relay:smoke": "node scripts/openclaw-publish-relay-smoke.mjs",
    "smoke:release": "python scripts/loom-release-smoke.py --require-provider --require-matrix",
    "smoke:release:phones": "python scripts/loom-release-smoke.py --require-provider --require-matrix --require-phone-count 1",
    "smoke:matrix:soak": "python scripts/loom-matrix-soak.py --duration-sec 300 --min-devices 2",
    "phone:demo:shopping": "node scripts/openclaw-phone-demo.mjs shopping",
    "phone:demo:read": "node scripts/openclaw-phone-demo.mjs read",
    "phone:demo:game": "node scripts/openclaw-phone-demo.mjs game",
    "desktop:agent": "node scripts/openclaw-desktop-agent.mjs",
    "desktop:reply": "node scripts/openclaw-desktop-agent.mjs reply",
    "loom:cli": "python python/loom_cli.py",
    "loom:mcp": "python python/loom_mcp.py",
    "loom:context": "node scripts/openclaw-context.mjs",
    "loom:phone": "node scripts/openclaw-phone-agent.mjs",
    "loom:phone:fleet": "node scripts/openclaw-phone-fleet.mjs",
    "loom:phone:vision": "node scripts/openclaw-phone-vision.mjs",
    "loom:phone:video": "node scripts/openclaw-phone-video.mjs",
    "loom:phone:publish": "node scripts/openclaw-publish-phone.mjs",
    "loom:image": "node scripts/openclaw-image-phone.mjs",
    "loom:desktop": "node scripts/openclaw-desktop-agent.mjs",
    "loom:desktop:reply": "node scripts/openclaw-desktop-agent.mjs reply",
    "measure:cold-start": "powershell -ExecutionPolicy Bypass -File scripts/measure-cold-start.ps1",
    "openclaw:context": "node scripts/openclaw-context.mjs",
    "package:mac:complete": "node scripts/package-mac-complete.mjs",
    "package:mac:online": "node scripts/package-mac-online.mjs",
    "stage:protected": "node scripts/stage-protected-release.mjs",
    "verify:protected": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-protected-release.ps1",
    "package:protected:nsis": "npm run stage:protected && npm run verify:protected && npm run tauri -- build --bundles nsis --config src-tauri/tauri.protected.conf.json",
    "release:update-assets": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-desktop-update-release.ps1",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@types/qrcode-generator": "^0.0.16",
    "lucide-react": "^1.24.0",
    "qrcode-generator": "^2.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.19",
    "javascript-obfuscator": "4.1.1",
    "postcss": "^8.4.38",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.23.1",
    "typescript": "^5.5.0",
    "vite": "8.0.16"
  }
}
