{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loom.matrix.screen.v1",
  "title": "LOOM Matrix Screen v1",
  "type": "object",
  "required": [
    "schema",
    "deviceId",
    "capturedAt",
    "screenHash",
    "mime",
    "width",
    "height",
    "notModified"
  ],
  "properties": {
    "schema": {
      "const": "loom.matrix.screen.v1"
    },
    "deviceId": {
      "type": "string",
      "minLength": 1
    },
    "capturedAt": {
      "type": "string",
      "format": "date-time"
    },
    "screenHash": {
      "type": "string",
      "pattern": "^sha256:.+"
    },
    "mime": {
      "enum": [
        "image/jpeg",
        "image/png",
        "image/webp"
      ]
    },
    "width": {
      "type": "integer",
      "minimum": 1
    },
    "height": {
      "type": "integer",
      "minimum": 1
    },
    "image": {
      "type": "string",
      "minLength": 1,
      "contentEncoding": "base64"
    },
    "notModified": {
      "type": "boolean"
    }
  },
  "oneOf": [
    {
      "properties": {
        "notModified": {
          "const": true
        }
      },
      "not": {
        "required": [
          "image"
        ]
      }
    },
    {
      "properties": {
        "notModified": {
          "const": false
        }
      },
      "required": [
        "image"
      ]
    }
  ],
  "additionalProperties": false
}
