    <!-- Guide -->
    <string name="guide_page_title">Permission Setup</string>
    <string name="guide_page_subtitle">Please enable the following permissions for the app to work properly</string>
    <string name="guide_skip">Skip</string>
    <string name="guide_start">Get Started</string>
    <string name="guide_title_accessibility">Accessibility Service</string>
    <string name="guide_desc_accessibility">This is the core permission for AI to control your device.\n\n1. Go to Settings → Accessibility → Downloaded apps\n2. Find \"Lumi Agent Phone\" in the list\n3. Turn on the switch\n4. Confirm in the system dialog</string>
    <string name="guide_title_notification">Persistent Notification</string>
    <string name="guide_desc_notification">Keeps the app running in the background to prevent it from being killed by the system.\n\nJust tap the card on the home screen to enable it. Android 13+ will ask for notification permission first.</string>
    <string name="guide_title_overlay">System Overlay</string>
    <string name="guide_desc_overlay">Displays a floating panel showing AI execution status.\n\n1. Go to Settings → Apps → Lumi Agent Phone\n2. Find \"Display over other apps\"\n3. Turn on the switch</string>
    <string name="guide_title_battery">Battery Whitelist</string>
    <string name="guide_desc_battery">Prevents the system from stopping the app in the background.\n\nTap the card on the home screen, then confirm \"Allow\" in the system dialog. (Some devices may require setting to \"Unrestricted\")</string>
    <string name="guide_title_storage">File Access</string>
    <string name="guide_desc_storage">Allows the AI to read and write files on your device.\n\nAndroid 11+: Go to Settings → enable \"All files access\"\nAndroid 10 and below: Grant permission in the popup dialog</string>

