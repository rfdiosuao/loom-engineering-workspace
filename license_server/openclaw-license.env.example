# Copy this file to /opt/openclaw-license/openclaw-license.env on the server.
# Keep the production file out of git and restrict it with: chmod 600.
#
# Use the same token in:
# - launcher publish page Relay Token
# - CLI --relay-token
# - APKClaw publish relay settings
OPENCLAW_PUBLISH_RELAY_TOKEN=replace-with-long-random-token
