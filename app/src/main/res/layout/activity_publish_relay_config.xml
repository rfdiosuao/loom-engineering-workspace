<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBgSecondary"
    android:orientation="vertical">

    <com.apk.claw.android.widget.CommonToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56pt" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingHorizontal="16pt"
        android:paddingTop="16pt">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="4pt"
                android:paddingBottom="16pt"
                android:text="@string/publish_relay_config_tip"
                android:textColor="@color/colorTextSecondary"
                android:textSize="14pt" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="@string/publish_relay_config_base_url"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14pt"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12pt"
                app:cardElevation="1pt">

                <EditText
                    android:id="@+id/etBaseUrl"
                    android:layout_width="match_parent"
                    android:layout_height="48pt"
                    android:background="@null"
                    android:hint="@string/publish_relay_config_base_url_hint"
                    android:inputType="textUri"
                    android:maxLines="1"
                    android:paddingHorizontal="16pt"
                    android:singleLine="true"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextTertiary"
                    android:textSize="15pt" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20pt"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="@string/publish_relay_config_channel_id"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14pt"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12pt"
                app:cardElevation="1pt">

                <EditText
                    android:id="@+id/etChannelId"
                    android:layout_width="match_parent"
                    android:layout_height="48pt"
                    android:background="@null"
                    android:hint="@string/publish_relay_config_channel_id_hint"
                    android:inputType="text"
                    android:maxLines="1"
                    android:paddingHorizontal="16pt"
                    android:singleLine="true"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextTertiary"
                    android:textSize="15pt" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20pt"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="@string/publish_relay_config_token"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14pt"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12pt"
                app:cardElevation="1pt">

                <EditText
                    android:id="@+id/etRelayToken"
                    android:layout_width="match_parent"
                    android:layout_height="48pt"
                    android:background="@null"
                    android:hint="@string/publish_relay_config_token_hint"
                    android:inputType="textVisiblePassword"
                    android:maxLines="1"
                    android:paddingHorizontal="16pt"
                    android:singleLine="true"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextTertiary"
                    android:textSize="15pt" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20pt"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12pt"
                app:cardElevation="1pt">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64pt"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16pt">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/publish_relay_config_enabled"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="15pt"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4pt"
                            android:text="@string/publish_relay_config_enabled_desc"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="12pt" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/swEnabled"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16pt"
                android:paddingHorizontal="4pt"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13pt" />

            <com.apk.claw.android.widget.KButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="48pt"
                android:layout_marginTop="24pt"
                android:text="@string/common_save"
                android:textSize="16pt" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
