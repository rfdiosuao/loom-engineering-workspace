{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loom.agent.run.v1",
  "title": "LOOM Agent Run v1",
  "type": "object",
  "required": [
    "schema",
    "runId",
    "sessionId",
    "status",
    "campaignIds"
  ],
  "properties": {
    "schema": {
      "const": "loom.agent.run.v1"
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "queued",
        "running",
        "waiting_approval",
        "paused",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "checkpoint": {
      "type": "string",
      "minLength": 1
    },
    "campaignIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time"
    },
    "error": {
      "$ref": "#/$defs/error"
    }
  },
  "$defs": {
    "error": {
      "type": "object",
      "required": [
        "code",
        "message",
        "recoverable"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "recoverable": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
