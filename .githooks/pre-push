#!/bin/sh

if [ "${LOOM_ALLOW_MAIN_PUSH:-0}" = "1" ]; then
  exit 0
fi

while read local_ref local_sha remote_ref remote_sha
do
  if [ "$remote_ref" = "refs/heads/main" ] || [ "$remote_ref" = "refs/heads/master" ]; then
    echo "LOOM policy: direct pushes to the default branch are blocked." >&2
    echo "Push a codex/* branch and open a pull request." >&2
    echo "For an approved emergency only, set LOOM_ALLOW_MAIN_PUSH=1 for one command." >&2
    exit 1
  fi
done

exit 0
